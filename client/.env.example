VITE_THIRDWEB_CLIENT_ID=your_thirdweb_client_id
VITE_THIRDWEB_LOGIN_METHODS=google,email,passkey
VITE_THIRDWEB_AUTH_MODE=popup
VITE_THIRDWEB_EXTERNAL_WALLETS=io.metamask,com.coinbase.wallet

# Optional: enables SIWE auth in ConnectButton when you expose these endpoints:
# POST /login-payload
# POST /login
# POST /is-logged-in
# POST /logout
VITE_THIRDWEB_AUTH_BASE_URL=http://localhost:3000/api/auth
